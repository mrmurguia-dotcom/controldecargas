<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>M2 - Sistema Logístico</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/html5-qrcode"></script>
  <style>
    .bg-m2 { background-color: #1e3a5f; }
    .text-m2 { color: #1e3a5f; }
    .btn-orange { background-color: #f59e0b; }
    .btn-orange:hover { background-color: #d97706; }
    #reader { width: 100%; border-radius: 15px; overflow: hidden; }
  </style>
</head>
<body class="bg-slate-100 min-h-screen">

  <header class="bg-m2 text-white p-4 shadow-lg flex justify-between items-center">
    <h1 class="font-black italic text-xl">M2 LOGÍSTICA</h1>
    <div id="status-online" class="h-3 w-3 bg-green-400 rounded-full"></div>
  </header>

  <main class="p-4 max-w-lg mx-auto">

    <section id="importador" class="bg-white rounded-2xl p-6 shadow-sm mb-6 border-t-4 border-orange-500">
      <h2 class="font-bold text-m2 mb-4 flex items-center gap-2">📦 IMPORTAR CARGA EXCEL</h2>
      <div class="flex gap-2">
        <input type="number" id="nroCargaImport" placeholder="Ej: 8612" class="flex-1 p-3 border rounded-xl outline-none focus:ring-2 ring-orange-500">
        <button onclick="importarExcel()" id="btnImport" class="btn-orange text-white px-4 py-3 rounded-xl font-bold shadow-md active:scale-95 transition-all">IMPORTAR</button>
      </div>
      <p id="msgImport" class="text-xs mt-2 text-slate-500 font-medium"></p>
    </section>

    <section class="bg-white rounded-2xl p-6 shadow-sm mb-6 border-t-4 border-blue-500">
      <h2 class="font-bold text-m2 mb-4 flex items-center gap-2">📷 ESCÁNER DE CONTROL</h2>
      <div id="reader" class="mb-4"></div>
      <div id="scanResult" class="text-center p-3 rounded-xl bg-slate-50 font-bold text-lg text-slate-600">Esperando escaneo...</div>
    </section>

    <section class="bg-white rounded-2xl p-6 shadow-sm border-t-4 border-slate-400">
      <h2 class="font-bold text-m2 mb-4">🔍 CONSULTAR CP</h2>
      <div class="flex gap-2 mb-4">
        <input type="number" id="inputCP" placeholder="N° de CP" class="flex-1 p-3 border rounded-xl outline-none">
        <button onclick="buscarCP()" class="bg-m2 text-white px-6 py-3 rounded-xl font-bold">VER</button>
      </div>
      <div id="listaItems" class="space-y-3"></div>
    </section>

  </main>

  <script>
    // --- LÓGICA DE IMPORTACIÓN ---
    function importarExcel() {
      const carga = document.getElementById('nroCargaImport').value;
      if(!carga) return alert("Ingresá un número de carga");
      
      const btn = document.getElementById('btnImport');
      const msg = document.getElementById('msgImport');
      
      btn.disabled = true;
      btn.innerText = "PROCESANDO...";
      msg.innerText = "Buscando archivo en Drive y creando pestaña...";

      google.script.run
        .withSuccessHandler(res => {
          btn.disabled = false;
          btn.innerText = "IMPORTAR";
          msg.innerText = "✅ " + res;
          alert(res);
        })
        .withFailureHandler(err => {
          btn.disabled = false;
          btn.innerText = "IMPORTAR";
          msg.innerText = "❌ Error: " + err;
        })
        .importarExcelDesdeDrive(carga); // Esta función la agregaremos a tu .gs
    }

    // --- LÓGICA DE ESCÁNER ---
    function onScanSuccess(decodedText) {
      document.getElementById('scanResult').innerText = "Validando: " + decodedText;
      document.getElementById('scanResult').className = "text-orange-500 font-bold text-center p-3";
      
      google.script.run
        .withSuccessHandler(res => {
          if(res.encontrado) {
            document.getElementById('scanResult').innerText = "✅ " + res.msg;
            document.getElementById('scanResult').className = "text-green-600 font-bold text-center p-3 bg-green-50 rounded-xl";
          } else {
            document.getElementById('scanResult').innerText = "❌ " + res.msg;
            document.getElementById('scanResult').className = "text-red-600 font-bold text-center p-3 bg-red-50 rounded-xl";
          }
        })
        .validarItemScan(decodedText); // Esta función la agregaremos a tu .gs
    }

    let html5QrcodeScanner = new Html5QrcodeScanner("reader", { fps: 10, qrbox: 250 });
    html5QrcodeScanner.render(onScanSuccess);

    // --- BUSCADOR DE CP (Usa tu función buscarCPChofer) ---
    function buscarCP() {
      const cp = document.getElementById('inputCP').value;
      google.script.run.withSuccessHandler(res => {
        const div = document.getElementById('listaItems');
        div.innerHTML = `<p class="text-sm font-bold text-slate-500">Fecha: ${res.fecha}</p>`;
        res.listaClientes.forEach(cli => {
          div.innerHTML += `
            <div class="p-3 border rounded-lg bg-slate-50">
              <p class="font-bold text-sm">${cli.nombre}</p>
              <p class="text-xs text-slate-400">${cli.direccion}</p>
            </div>
          `;
        });
      }).buscarCPChofer(cp);
    }
  </script>
</body>
</html>
